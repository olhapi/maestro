class Maestro < Formula
  desc "Docker-backed launcher for Maestro"
  homepage "https://maestro.olhapi.com"
  url "https://registry.npmjs.org/@olhapi/maestro/-/olhapi-maestro-__VERSION__.tgz"
  sha256 "__SHA256__"
  license "MIT"

  depends_on "docker"
  depends_on "node"

  def install
    libexec.install Dir["*"]
    bin.install_symlink libexec/"bin/maestro" => "maestro"
  end

  test do
    assert_match "__VERSION__", shell_output("#{bin}/maestro version 2>&1", 1)
  end
end
