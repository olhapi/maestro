---
const { title, description, href, label } = Astro.props;
---

{
  href ? (
    <a class="panel block h-full p-6 transition hover:border-white/14 hover:bg-white/5" href={href}>
      {label ? <p class="kicker !mb-4 !text-[0.72rem]">{label}</p> : null}
      <h3 class="font-display text-2xl font-semibold tracking-tight text-white">{title}</h3>
      <p class="mt-3 text-sm leading-7 text-[var(--muted)] md:text-base">{description}</p>
    </a>
  ) : (
    <article class="panel h-full p-6">
      {label ? <p class="kicker !mb-4 !text-[0.72rem]">{label}</p> : null}
      <h3 class="font-display text-2xl font-semibold tracking-tight text-white">{title}</h3>
      <p class="mt-3 text-sm leading-7 text-[var(--muted)] md:text-base">{description}</p>
    </article>
  )
}
