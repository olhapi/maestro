---
import type { MarkdownHeading } from "astro";
import { getCollection } from "astro:content";

import DocsSidebar from "../components/DocsSidebar.astro";
import TableOfContents from "../components/TableOfContents.astro";
import BaseLayout from "./BaseLayout.astro";
import { getDocHref, groupDocs } from "../lib/docs";

const { title, description, path, headings = [], currentHref } = Astro.props as {
  title: string;
  description: string;
  path: string;
  headings?: MarkdownHeading[];
  currentHref: string;
};
const groups = groupDocs(await getCollection("docs"));
const visibleHeadings = headings.filter((heading: MarkdownHeading) => heading.depth <= 3);
---

<BaseLayout activeNav="/docs" description={description} path={path} title={title}>
  <section class="section-shell py-10 md:py-14">
    <div class="grid gap-6 lg:grid-cols-[17rem_minmax(0,1fr)] xl:grid-cols-[17rem_minmax(0,1fr)_15rem]">
      <DocsSidebar currentHref={currentHref} groups={groups} />

      <div class="grid min-w-0 gap-4">
        <div class="grid gap-3 lg:hidden">
          <details class="panel overflow-hidden">
            <summary class="flex list-none items-start justify-between gap-3 px-5 py-4 text-left">
              <div>
                <p class="font-display text-lg font-semibold text-white">Browse docs</p>
                <p class="mt-1 text-sm text-[var(--muted)]">Move across sections without leaving the current page.</p>
              </div>
              <span class="rounded-full border border-white/10 px-3 py-1 text-[0.68rem] uppercase tracking-[0.16em] text-[var(--muted)]">Open</span>
            </summary>
            <div class="border-t border-white/8 px-4 py-4">
              <div class="space-y-5">
                {groups.map((group) => (
                  <section>
                    <h2 class="font-display text-sm font-semibold tracking-wide text-white">{group.title}</h2>
                    <div class="mt-3 space-y-1.5">
                      {group.items.map((entry) => {
                        const href = getDocHref(entry);
                        const active = href === currentHref;
                        return (
                          <a
                            class:list={[
                              "block rounded-2xl border px-3 py-2 text-sm transition",
                              active
                                ? "border-[rgba(196,255,87,0.3)] bg-[rgba(196,255,87,0.1)] text-white"
                                : "border-transparent text-[var(--muted)] hover:border-white/8 hover:bg-white/5 hover:text-white",
                            ]}
                            href={href}
                          >
                            {entry.data.navLabel ?? entry.data.title}
                          </a>
                        );
                      })}
                    </div>
                  </section>
                ))}
              </div>
            </div>
          </details>

          {
            visibleHeadings.length > 0 ? (
              <details class="panel hidden overflow-hidden md:block">
                <summary class="flex list-none items-start justify-between gap-3 px-5 py-4 text-left">
                  <div>
                    <p class="font-display text-lg font-semibold text-white">On this page</p>
                    <p class="mt-1 text-sm text-[var(--muted)]">Jump to the sections below without scrolling manually.</p>
                  </div>
                  <span class="rounded-full border border-white/10 px-3 py-1 text-[0.68rem] uppercase tracking-[0.16em] text-[var(--muted)]">Open</span>
                </summary>
                <div class="border-t border-white/8 px-4 py-4">
                  <nav class="space-y-2">
                    {visibleHeadings.map((heading) => (
                      <a
                        class:list={[
                          "block rounded-2xl px-3 py-2 text-sm leading-6 text-[var(--muted)] transition hover:bg-white/5 hover:text-white",
                          heading.depth === 3 ? "pl-6" : "",
                        ]}
                        href={`#${heading.slug}`}
                      >
                        {heading.text}
                      </a>
                    ))}
                  </nav>
                </div>
              </details>
            ) : null
          }
        </div>

        <article class="panel min-w-0 p-6 md:p-8">
          <h1 class="font-display text-4xl font-semibold leading-[1.02] tracking-tight text-white md:text-6xl">{title}</h1>
          <p class="mt-4 max-w-3xl text-base leading-7 text-[var(--muted)] md:text-lg">{description}</p>
          <div class="docs-copy mt-10 min-w-0">
            <slot />
          </div>
        </article>
      </div>

      <TableOfContents headings={headings} />
    </div>
  </section>
</BaseLayout>
