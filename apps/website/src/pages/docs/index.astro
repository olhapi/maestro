---
import { getCollection } from "astro:content";

import FeatureCard from "../../components/FeatureCard.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import CommandBlock from "../../components/react/CommandBlock";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getDocHref, groupDocs } from "../../lib/docs";
import { quickstartSteps } from "../../site.config";

const groups = groupDocs(await getCollection("docs"));
---

<BaseLayout
  activeNav="/docs"
  description="Read the Maestro docs to install the Codex loop, hand off work safely, and step back in through the control center when you need control."
  path="/docs"
  title="Documentation"
>
  <section class="section-shell pb-12 pt-10 md:pb-16 md:pt-16">
    <div class="grid gap-8">
      <div>
        <h1 class="font-display text-[clamp(2rem,4.4vw,3.45rem)] font-semibold leading-[0.96] tracking-tight text-white">
          Maestro documentation
        </h1>
        <p class="mt-6 text-lg leading-8 text-[var(--muted)] md:text-xl">
          Start with install and quickstart, then learn how Maestro keeps Codex moving, what the control center is telling you, and which knobs matter when you need to step back in.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="button-primary" href="/docs/quickstart">Open quickstart</a>
          <button class="button-secondary" data-search-trigger type="button">Search docs</button>
        </div>
      </div>
      <div class="panel min-w-0 p-6">
        <div class="grid min-w-0 gap-4 lg:grid-cols-3">
          {quickstartSteps.map((step) => <CommandBlock client:load command={step.command} detail={step.detail} title={step.title} />)}
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell pb-18 md:pb-24">
    <SectionHeading
      description="Each section maps to a real operator moment: install, make the first handoff, understand what Codex is doing, then tune or debug it when needed."
      title="Read by the moment you need to step back in"
    />
    <div class="mt-8 grid gap-4 lg:grid-cols-2">
      {groups.map((group) => (
        <div class="panel p-6">
          <p class="kicker !mb-4">{group.title}</p>
          <p class="text-base leading-7 text-[var(--muted)]">{group.description}</p>
          <div class="mt-5 space-y-3">
            {group.items.map((entry) => (
              <a class="block rounded-2xl border border-white/8 bg-black/20 px-4 py-3 transition hover:border-white/14 hover:bg-white/5" href={getDocHref(entry)}>
                <span class="block font-medium text-white">{entry.data.navLabel ?? entry.data.title}</span>
                <p class="mt-2 text-sm leading-6 text-[var(--muted)]">{entry.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section-shell pb-18">
    <SectionHeading
      description="If you already know where the friction is, jump straight to the page that helps you start the loop, read its state, or change how it behaves."
      title="Three common re-entry points"
    />
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <FeatureCard
        description="Use this when you want the shortest path from install to a Codex loop that keeps working while you move on."
        href="/docs/quickstart"
        title="Install and quickstart"
      />
      <FeatureCard
        description="Use this when Maestro is already running and you need to decide whether to intervene or let Codex continue."
        href="/docs/control-center"
        title="Control center"
      />
      <FeatureCard
        description="Use this when the loop is running but you need tighter control over dispatch, retries, or guardrails."
        href="/docs/workflow-config"
        title="Workflow config"
      />
    </div>
  </section>
</BaseLayout>
