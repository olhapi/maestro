---
const { context = "docs" } = Astro.props as {
  context?: "docs" | "home";
};

const isHome = context === "home";

const sections = [
  {
    description: isHome
      ? "Attach through MCP, keep the daemon in the middle, and let provider sync plus orchestration stay local."
      : "",
    image: isHome
      ? {
          alt: "Architecture diagram showing the MCP client and HTTP server paths flowing into the Maestro daemon, which coordinates providers, orchestration, storage, and the agent runner.",
          height: 780,
          src: "/images/screens/architecture-runtime.svg",
          width: 1280,
        }
      : {
          alt: "Screenshot of the live loop architecture diagram showing MCP and HTTP entry points flowing into the Maestro runtime, which then coordinates providers, orchestration, storage, and the agent runner.",
          height: 606,
          src: "/images/screens/architecture-live-loop.png",
          width: 572,
        },
  },
] as const;
---

<div>
  {sections.map((section) => (
    <section class="p-2">
      <img
        alt={section.image.alt}
        class="architecture-diagram-image"
        height={section.image.height}
        loading="lazy"
        src={section.image.src}
        width={section.image.width}
      />
    </section>
  ))}
</div>
