{
  "name": "maestro-workspace",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "prepare": "husky",
    "build": "turbo build",
    "check": "turbo check",
    "dev": "./scripts/dev.sh",
    "dev:apps": "turbo dev --parallel --filter=@maestro/frontend --filter=@maestro/website",
    "lint": "turbo lint",
    "smoke": "turbo smoke",
    "test": "turbo test:ci",
    "verify": "pnpm verify:go && pnpm verify:web && pnpm verify:coverage && pnpm verify:package",
    "verify:coverage": "pnpm frontend:test:coverage && pnpm website:test:coverage",
    "verify:pre-push": "pnpm verify && ./scripts/git-hooks/host-package-smoke.sh && go test ./internal/orchestrator -run TestSharedDBStressPreventsRunawayRetriesAndLockContention -count=1 && ./scripts/git-hooks/retry-safety-e2e.sh",
    "verify:ci": "pnpm verify:web && pnpm verify:package",
    "verify:frontend": "pnpm frontend:lint && pnpm frontend:test",
    "verify:website": "pnpm website:check && pnpm website:test",
    "verify:web": "pnpm lint && pnpm test && pnpm check && pnpm smoke",
    "verify:go": "make build && make test && make test-cover && make test-race",
    "verify:package": "node --test packaging/npm/root/lib/get-exe-path.test.js scripts/smoke_installed_dashboard.test.mjs scripts/verify-pipeline.test.mjs && bash ./scripts/check_coverage.test.sh && bash ./scripts/e2e_harness_bootstrap.test.sh && bash ./scripts/publish_npm_release.test.sh",
    "release:npm": "./scripts/publish_npm_release.sh",
    "hooks:pre-commit": "./scripts/git-hooks/pre-commit.sh",
    "hooks:pre-push": "./scripts/git-hooks/pre-push.sh",
    "frontend:dev": "pnpm --filter @maestro/frontend dev",
    "frontend:build": "turbo build --filter=@maestro/frontend",
    "frontend:lint": "turbo lint --filter=@maestro/frontend",
    "frontend:leak-hunt": "pnpm --filter @maestro/frontend leak:hunt",
    "frontend:test": "turbo test:ci --filter=@maestro/frontend",
    "frontend:test:coverage": "pnpm --filter @maestro/frontend test:coverage",
    "website:dev": "pnpm --filter @maestro/website dev",
    "website:build": "turbo build --filter=@maestro/website",
    "website:check": "turbo check --filter=@maestro/website",
    "website:test": "turbo test:ci --filter=@maestro/website",
    "website:test:coverage": "pnpm --filter @maestro/website test:coverage",
    "website:smoke": "turbo smoke --filter=@maestro/website"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "turbo": "^2.9.6"
  }
}
